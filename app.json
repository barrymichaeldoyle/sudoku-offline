{
  "expo": {
    "name": "Sudoku",
    "slug": "sudoku-offline",
    "version": "1.1.2",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sudokuoffline",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.barrymichaeldoyle.sudokuoffline",
      "supportsTablet": true,
      "associatedDomains": ["applinks:sudokuoffline.expo.app"],
      "config": {
        "usesNonExemptEncryption": false
      },
      "appleTeamId": "LBZ6C9H52C"
    },
    "android": {
      "package": "com.barrymichaeldoyle.sudokuoffline",
      "adaptiveIcon": {
        "backgroundColor": "#F7F3EA",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [{ "scheme": "https", "host": "sudokuoffline.expo.app" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "output": "server",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#2F3A5F",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/android-icon-monochrome.png",
          "color": "#2F3A5F",
          "defaultChannel": "daily-reminders",
          "enableBackgroundRemoteNotifications": false
        }
