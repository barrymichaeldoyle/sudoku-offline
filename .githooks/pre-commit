#!/bin/sh
#
# Pre-commit: format and lint staged source files with oxfmt + oxlint.
# Formatting fixes are applied and re-staged automatically; lint errors block
# the commit. Skips vendored/reference dirs (example/, docs/, .agents/, .claude/).

set -e

# Staged files (Added, Copied, Modified, Renamed) with lintable/formattable
# extensions, excluding template/prose/vendored-skill directories.
files=$(git diff --cached --name-only --diff-filter=ACMR \
  | grep -E '\.(ts|tsx|js|jsx|mjs|cjs|json|css)$' \
  | grep -Ev '^(example|docs|\.agents|\.claude)/' || true)

if [ -z "$files" ]; then
  exit 0
fi

# Format and re-stage. oxfmt is a no-op on already-clean files.
printf '%s\n' "$files" | xargs ./node_modules/.bin/oxfmt --write
printf '%s\n' "$files" | xargs git add

# Lint JS/TS only (oxlint does not lint JSON/CSS).
lint_files=$(printf '%s\n' "$files" | grep -E '\.(ts|tsx|js|jsx|mjs|cjs)$' || true)
if [ -n "$lint_files" ]; then
  printf '%s\n' "$lint_files" | xargs ./node_modules/.bin/oxlint
fi
