{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["scripts/**/*.{js,mjs}"],
  "project": ["src/**/*.{ts,tsx}", "scripts/**/*.{js,mjs}"],
  "ignoreFiles": ["src/domain/sudoku/index.ts", "src/tw/animated.tsx", "src/services/adService.ts"],
