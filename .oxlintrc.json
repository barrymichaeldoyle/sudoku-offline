{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "jsx-a11y", "import", "typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error",
    "perf": "warn"
  },
  "env": {
    "browser": true,
    "es2024": true
  },
  "globals": {
    "__DEV__": "readonly"
  },
  "rules": {
    "react/react-in-jsx-scope": "off",
    "no-restricted-imports": [
      "error",
      {
        "paths": [
          {
            "name": "react",
            "importNames": ["default"],
            "message": "Do not default-import React. Use named value imports and separate `import type` for types."
          }
        ]
      }
    ],
    "typescript/consistent-type-imports": [
      "error",
      {
        "prefer": "type-imports",
        "fixStyle": "separate-type-imports"
      }
    ]
  },
  "ignorePatterns": [
    ".expo",
    ".agents",
    ".claude",
    "dist",
    "node_modules",
    "expo-env.d.ts",
    "android",
    "ios",
    "example"
  ]
}
