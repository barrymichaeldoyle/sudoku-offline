{
  "cli": {
    "version": ">= 20.3.0",
    "appVersionSource": "remote",
    "metadataPath": "./store.config.js"
  },
  "build": {
    "base": {
      "node": "24.15.0",
      "pnpm": "11.8.0"
    },
    "development": {
      "extends": "base",
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "extends": "base",
      "distribution": "internal"
    },
    "production": {
      "extends": "base",
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "REPLACE_WITH_APP_STORE_CONNECT_APPLE_ID"
      }
    }
  }
}
