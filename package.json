{
  "name": "sudoku-offline",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit",
    "knip:check": "knip",
    "generate:puzzles": "node ./scripts/generate-puzzles.mjs",
    "generate:icons": "node ./scripts/generate-icons.mjs",
    "generate:screenshots": "node ./scripts/generate-store-screenshots.mjs",
    "capture:screenshots": "./scripts/capture-store-screenshots.sh",
    "metadata:pull": "eas metadata:pull",
    "metadata:push": "eas metadata:push",
    "ci:check": "pnpm typecheck && oxlint --deny-warnings && pnpm format:check && pnpm knip:check && pnpm test && pnpm audit --audit-level moderate",
    "release:ios": "./scripts/release-ios.sh"
  },
  "dependencies": {
    "@lottiefiles/dotlottie-react": "^0.19.8",
    "@tailwindcss/postcss": "^4.3.2",
    "clsx": "^2.1.1",
    "expo": "~57.0.4",
    "expo-constants": "~57.0.3",
    "expo-crypto": "~57.0.0",
    "expo-dev-client": "~57.0.5",
    "expo-haptics": "~57.0.0",
    "expo-iap": "^4.3.6",
    "expo-insights": "~57.0.2",
    "expo-linking": "~57.0.2",
    "expo-notifications": "~57.0.3",
    "expo-router": "~57.0.4",
    "expo-splash-screen": "~57.0.2",
    "expo-sqlite": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "lottie-react-native": "~7.3.8",
    "lucide-react-native": "^1.23.0",
    "nativewind": "5.0.0-preview.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-css": "3.0.7",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-google-mobile-ads": "^16.4.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "^15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0",
    "tailwindcss": "^4.3.2",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "jest": "^29.7.0",
    "jest-expo": "^57.0.1",
    "knip": "^6.25.0",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "typescript": "~7.0.2"
  },
  "expo": {
    "install": {
      "exclude": [
        "typescript"
      ]
    }
  }
}
